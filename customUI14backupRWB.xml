<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="RibbonOnLoad">
  <ribbon startFromScratch="false">
    <tabs>
      <tab id="RWB" label="Radiant Word Bible">
        <group id="TestGroup" label="Bible Class Group">
          <button id="GoToMyVerse" label="GoTo Verse" imageMso="FormatNumberDefault" size="large" onAction="OnGoToVerseSblClick"/>
          <separator id="sep1"/>
          <button id="GoToPrevButton" imageMso="HeaderFooterPreviousSection" size="normal" showLabel="false" onAction="OnPrevButtonClick" getEnabled="GetPrevEnabled"/>
          <button id="GoToH1Button" imageMso="NotebookNew" size="normal" showLabel="false" onAction="OnGoToH1ButtonClick"/>
          <button id="GoToNextButton" imageMso="HeaderFooterNextSection" size="normal" showLabel="false" onAction="OnNextButtonClick" getEnabled="GetNextEnabled"/>
          <separator id="sep2"/>
          <button id="adaeptButton" label="About" image="adaept" size="large" onAction="OnAdaeptAboutClick"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>