<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="RibbonOnLoad">
  <ribbon startFromScratch="false">
    <tabs>
      <tab id="RWB" label="Radiant Word Bible">
        <group id="NavGroup" label="Bible Navigation">
          <box id="boxInputs" boxStyle="horizontal">
            <comboBox id="cmbBook" showLabel="false" sizeString="2 Thessalonians"
                      getItemCount="GetBookCount" getItemLabel="GetBookItemLabel"
                      getItemID="GetBookItemID" getText="GetBookText"
                      onChange="OnBookChanged" getEnabled="GetBookEnabled"/>
            <comboBox id="cmbChapter" showLabel="false" sizeString="2 Thessalonians"
                      getItemCount="GetChapterCount" getItemLabel="GetChapterItemLabel"
                      getItemID="GetChapterItemID" getText="GetChapterText"
                      onChange="OnChapterChanged" getEnabled="GetChapterEnabled"/>
            <comboBox id="cmbVerse" showLabel="false" sizeString="2 Thessalonians"
                      getItemCount="GetVerseCount" getItemLabel="GetVerseItemLabel"
                      getItemID="GetVerseItemID" getText="GetVerseText"
                      onChange="OnVerseChanged" getEnabled="GetVerseEnabled"/>
          </box>
          <box id="boxButtons" boxStyle="horizontal">
            <button id="PrevBookButton" imageMso="HeaderFooterPreviousSection" size="normal"
                    showLabel="false" onAction="OnPrevButtonClick" getEnabled="GetPrevEnabled"/>
            <button id="NextBookButton" imageMso="HeaderFooterNextSection" size="normal"
                    showLabel="false" onAction="OnNextButtonClick" getEnabled="GetNextEnabled"/>
            <button id="PrevChapterButton" imageMso="HeaderFooterPreviousSection" size="normal"
                    showLabel="false" onAction="OnPrevChapterClick" getEnabled="GetPrevChapterEnabled"/>
            <button id="NextChapterButton" imageMso="HeaderFooterNextSection" size="normal"
                    showLabel="false" onAction="OnNextChapterClick" getEnabled="GetNextChapterEnabled"/>
            <button id="PrevVerseButton" imageMso="HeaderFooterPreviousSection" size="normal"
                    showLabel="false" onAction="OnPrevVerseClick" getEnabled="GetPrevVerseEnabled"/>
            <button id="NextVerseButton" imageMso="HeaderFooterNextSection" size="normal"
                    showLabel="false" onAction="OnNextVerseClick" getEnabled="GetNextVerseEnabled"/>
          </box>
          <separator id="sep1"/>
          <button id="NewSearchButton" imageMso="Undo" size="normal" showLabel="false"
                  onAction="OnNewSearchClick" getEnabled="GetNewSearchEnabled"/>
          <separator id="sep2"/>
          <button id="adaeptButton" label="About" image="adaept" size="large"
                  onAction="OnAdaeptAboutClick"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
